# TICMI Environment Configuration

APP_NAME="TICMI - Teach Me"
APP_VERSION="0.2.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Use Supabase Postgres URL when available. For quick local run, keep sqlite.
DATABASE_URL=sqlite:///./ticmi.db
SUPABASE_URL=
SUPABASE_ANON_KEY=

# LLM Provider: mock | openrouter
DEFAULT_LLM_PROVIDER=mock
DEFAULT_LLM_MODEL=openrouter/free
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional NVIDIA fallback
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# CORS
CORS_ORIGINS=http://localhost:3000

# ChromaDB (future retrieval stage)
CHROMA_DB_HOST=localhost
CHROMA_DB_PORT=8001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
